{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "email"]
    },
    "Booking": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bookingReference": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "bookingDate": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "title": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "userId", "bookingReference", "totalAmount", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "User singleton profile document."
        }
      },
      {
        "path": "/users/{userId}/bookings/{bookingId}",
        "definition": {
          "entityName": "Booking",
          "description": "User confirmed bookings."
        }
      }
    ]
  }
}