rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOYAGEFLOW SECURITY RULES - PROTOTYPING MODE
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model for all personal travel data while 
     * providing authenticated read access to global travel services (flights, hotels, activities).
     * 
     * Data Structure:
     * - Personal data (profiles, baskets, bookings) is nested under /users/{userId}/...
     * - Travel services (flights, hotels, activities) are stored in top-level global collections.
     * 
     * Key Security Decisions:
     * - Access to user-specific data is strictly limited to the owner (request.auth.uid == userId).
     * - All travel services are readable by any authenticated user but protected from non-admin writes.
     * - Denormalization for Authorization: Sub-items (Basket Items and Booking Items) must include 
     *   a 'userProfileId' field matching the owner's UID. This enables "Authorization Independence," 
     *   allowing the rules to verify ownership without performing expensive get() calls to parent documents.
     * - Relational Integrity: On creation of user-scoped documents, the system validates that internal 
     *   linkage fields (like userProfileId) match the authenticated user's ID and the document's path.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user is the owner of an existing document. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Validates that the internal ownership field matches the user's ID. */
    function isValidRelationalOwner(data, userId) {
      return data.userProfileId == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile entity. Users manage their own profile info.
     * @path /users/{userId}/profile/{profileId}
     * @allow (create) User 'abc' creates a profile at /users/abc/profile/prof_1 with { id: 'abc' }.
     * @deny (list) User 'abc' attempts to list all profiles in /users/xyz/profile.
     * @principle Restricts access to a user's own data tree and enforces self-creation.
     */
    match /users/{userId}/profile/{profileId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Globally discoverable flight services.
     * @path /flights/{flightId}
     * @allow (get) Any authenticated user reads flight details.
     * @deny (create) An authenticated user attempts to create a new flight record.
     * @principle Public read for authenticated users with owner-only (admin) writes.
     */
    match /flights/{flightId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // TODO: Restrict to users with 'admin' role in custom claims or admin collection.
    }

    /**
     * @description Globally discoverable hotel services.
     * @path /hotels/{hotelId}
     * @allow (list) Any authenticated user lists available hotels.
     * @deny (delete) A user attempts to delete a hotel record.
     * @principle Public read for authenticated users with owner-only (admin) writes.
     */
    match /hotels/{hotelId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // TODO: Restrict to users with 'admin' role.
    }

    /**
     * @description Globally discoverable activity services.
     * @path /activities/{activityId}
     * @allow (get) Any authenticated user reads activity details.
     * @deny (update) A user attempts to update activity pricing.
     * @principle Public read for authenticated users with owner-only (admin) writes.
     */
    match /activities/{activityId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // TODO: Restrict to users with 'admin' role.
    }

    /**
     * @description Stores a user's temporary booking basket.
     * @path /users/{userId}/bookingBaskets/{basketId}
     * @allow (create) User 'abc' creates a basket with userProfileId 'abc'.
     * @deny (get) User 'abc' attempts to read a basket belonging to user 'xyz'.
     * @principle Enforces path-based ownership and relational integrity.
     */
    match /users/{userId}/bookingBaskets/{basketId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidRelationalOwner(request.resource.data, userId);
      allow update: if isExistingOwner(userId) && isValidRelationalOwner(request.resource.data, userId);
      allow delete: if isExistingOwner(userId);

      /**
       * @description Individual items within a user's booking basket.
       * @path /users/{userId}/bookingBaskets/{basketId}/items/{itemId}
       * @allow (list) User 'abc' lists items in their own basket.
       * @deny (create) User 'abc' creates an item with userProfileId 'xyz'.
       * @principle Authorization independence via denormalized ownership field.
       */
      match /items/{itemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidRelationalOwner(request.resource.data, userId);
        allow update: if isExistingOwner(userId) && isValidRelationalOwner(request.resource.data, userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Stores confirmed bookings made by a user.
     * @path /users/{userId}/bookings/{bookingId}
     * @allow (get) User 'abc' retrieves their confirmed booking record.
     * @deny (update) User 'abc' tries to change the userProfileId on an existing booking.
     * @principle Enforces strict ownership and immutable relational links.
     */
    match /users/{userId}/bookings/{bookingId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidRelationalOwner(request.resource.data, userId);
      allow update: if isExistingOwner(userId) && isValidRelationalOwner(request.resource.data, userId) && request.resource.data.userProfileId == resource.data.userProfileId;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Services within a confirmed booking.
       * @path /users/{userId}/bookings/{bookingId}/items/{bookedItemId}
       * @allow (get) User 'abc' views a specific flight item within their booking.
       * @deny (list) User 'xyz' attempts to list items in 'abc's booking.
       * @principle Authorization independence via denormalized ownership field.
       */
      match /items/{bookedItemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidRelationalOwner(request.resource.data, userId);
        allow update: if isExistingOwner(userId) && isValidRelationalOwner(request.resource.data, userId);
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}