rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VoyageFlow Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model combined with role-based access for administrative 
     * functions. Data access is primarily governed by the user's identity as established via Firebase Auth.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function dataMatchesOwner(userId) {
      return request.resource.data.userProfileId == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profiles.
     * Path: /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isOwner(userId);

      /**
       * @description Temporary shopping baskets for users.
       */
      match /bookingBaskets/{basketId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && dataMatchesOwner(userId);
        allow update: if isExistingOwner(userId) && dataMatchesOwner(userId) && request.resource.data.userProfileId == resource.data.userProfileId;
        allow delete: if isExistingOwner(userId);

        match /items/{itemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && dataMatchesOwner(userId);
          allow update: if isExistingOwner(userId) && dataMatchesOwner(userId) && request.resource.data.userProfileId == resource.data.userProfileId;
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Confirmed travel bookings.
       */
      match /bookings/{bookingId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && dataMatchesOwner(userId);
        allow update: if isExistingOwner(userId) && dataMatchesOwner(userId) && request.resource.data.userProfileId == resource.data.userProfileId;
        allow delete: if isExistingOwner(userId);

        match /items/{bookedItemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && dataMatchesOwner(userId);
          allow update: if isExistingOwner(userId) && dataMatchesOwner(userId) && request.resource.data.userProfileId == resource.data.userProfileId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }

    /**
     * @description Global catalogs (Flights, Hotels, Activities)
     */
    match /flights/{flightId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /hotels/{hotelId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Internal administrative roles.
     */
    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}