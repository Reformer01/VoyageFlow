rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VoyageFlow Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model. Data access is primarily 
     * governed by the user's identity as established via Firebase Auth.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profiles.
     * Path: /users/{userId}
     */
    match /users/{userId} {
      // Allow owners to read and write their own profile document
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);

      /**
       * @description Temporary shopping baskets for users.
       */
      match /bookingBaskets/{basketId} {
        allow read, write: if isOwner(userId);
        
        match /items/{itemId} {
          allow read, write: if isOwner(userId);
        }
      }

      /**
       * @description Confirmed travel bookings.
       */
      match /bookings/{bookingId} {
        allow read, write: if isOwner(userId);

        match /booking_items/{bookedItemId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    /**
     * @description Global catalogs (Flights, Hotels, Activities)
     */
    match /flights/{flightId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only via console
    }

    match /hotels/{hotelId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}